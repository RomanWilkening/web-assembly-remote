# Remote Desktop Server Configuration

[auth]
# Login credentials for the web interface.
# Change these values before deploying!
username = "admin"
password = "changeme"

# Audio output device for loopback capture (optional).
#
# Available audio output devices are auto-discovered and listed in the
# browser toolbar.  The user can select which output device to capture.
#
# Set this to auto-start capturing a specific device when a client
# connects.  Use "default" to capture the system default output.
# Leave commented out to let the user choose manually.
#
# On Windows this uses WASAPI loopback – no "Stereo Mix" or virtual
# audio cable required.  Any audio playing through the selected
# output device is streamed to the browser automatically.
#
# On Linux this uses PulseAudio (monitor sources capture output audio).
#
# Examples:
#   audio_device = "default"
#   audio_device = "Speakers (Realtek High Definition Audio)"
#
# audio_device = ""
